# INBEX Backend — Environment Variables

# Server
PORT=3000

# JWT Authentication (this is YOUR secret — any random string works)
SECRET_KEY=change-this-to-any-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Groq API (get your key at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# App
APP_NAME=INBEX
DEBUG=true
